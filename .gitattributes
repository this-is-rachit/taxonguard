# Normalize line endings. Git stores LF and checks out native on each OS.
* text=auto

# Always LF for files that break with CRLF
*.sh text eol=lf
*.py text eol=lf
Dockerfile text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Treat lockfiles and binaries correctly
uv.lock text eol=lf
*.lock text eol=lf
*.png binary
*.jpg binary
*.ico binary
*.tif binary
*.tiff binary
*.parquet binary
