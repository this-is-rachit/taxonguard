# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.env
.env.*
!.env.example
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# uv
# keep uv.lock committed; ignore nothing else specific

# Node / Next.js
node_modules/
.next/
out/
.turbo/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Data (large environmental layers and downloads are kept out of Git). Anchored
# to the repository root so it does not also match the source package
# packages/core/src/taxonguard_core/data/.
/data/
*.tif
*.tiff
*.zip
*.gpkg
*.parquet

# Generated evaluation results: the runner rewrites this on every run. The
# committed deliverables are the figure (docs/evaluation.png) and the writeup
# (docs/evaluation.md).
/docs/evaluation_results.json

# Generated by the real-data (held-out) evaluation, which is run live on the
# user's machine after a GBIF download. The figure and JSON are reproduced by
# re-running the command in docs/evaluation.md, so they are not committed.
/docs/evaluation_real_results.json
/docs/evaluation_real.png

# OS / editor
.DS_Store
Thumbs.db
.idea/
*.swp

# VS Code: keep shared settings, ignore local
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
