# Copy this file to .env and adjust as needed. All variables are optional for
# local development; defaults are sensible. The .env file is git-ignored.

# Display name for the API.
TAXONGUARD_APP_NAME=TaxonGuard API

# Log level: DEBUG, INFO, WARNING, ERROR.
TAXONGUARD_LOG_LEVEL=INFO

# Allowed CORS origins for the web app, as a JSON array.
TAXONGUARD_CORS_ORIGINS=["http://localhost:3000"]

# GBIF credentials for annotation write-back. Optional. With both set, confirming
# a cluster posts the rule to GBIF's experimental annotation system
# (https://labs.gbif.org/occurrence/experimental/annotation) over HTTP Basic Auth.
# Leave blank to run everything except write-back; the review screen then shows a
# manual copy-and-paste fallback. The tool runs at no cost without these.
TAXONGUARD_GBIF_USERNAME=
TAXONGUARD_GBIF_PASSWORD=
